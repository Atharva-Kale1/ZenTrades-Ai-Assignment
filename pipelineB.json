      "parameters": {
        "jsCode": "const items = $input.all();\n\nconst oldMemo = items[0].json;\nconst newMemo = items[1].json;\n\nconst updatedMemo = {...oldMemo};\nconst changes = {};\n\nfor (const key in newMemo) {\n\n  const oldValue = oldMemo[key];\n  const newValue = newMemo[key];\n\n  if (newValue === null || newValue === undefined) continue;\n\n  if (JSON.stringify(oldValue) !== JSON.stringify(newValue)) {\n\n    changes[key] = {\n      old: oldValue || null,\n      new: newValue,\n      reason: \"Updated during onboarding call\",\n      timestamp: new Date().toISOString()\n    };\n\n    updatedMemo[key] = newValue;\n  }\n}\n\nreturn [{\n  json: {\n    account_id: oldMemo.account_id,\n    updatedMemo,\n    changes\n  }\n}];"
